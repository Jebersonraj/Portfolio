pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/YOUR_USERNAME/YOUR_REPO.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    docker.build("my-app-image")
                }
            }
        }

        stage('Run Container') {
            steps {
                script {
                    docker.run("my-app-image")
                }
            }
        }
    }
}